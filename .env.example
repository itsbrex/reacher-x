# ============================================
# ReacherX Environment Variables
# ============================================
# Read docs/configuration.md before setting values.
# Copy this file to .env.local for the Next.js runtime:
# cp .env.example .env.local
#
# Convex backend functions do not load variables from .env.local. Set backend
# values per deployment with `npx convex env set`. Do not bulk-upload this file
# to Convex because it mixes local, public, and backend-only variables.

# ============================================
# Required: Core App Configuration
# ============================================

# Next.js: Convex client URL. `npx convex dev` normally writes this value.
NEXT_PUBLIC_CONVEX_URL=

# Next.js + Convex: WorkOS application client ID. Set the same client ID in the
# selected Convex deployment so convex/auth.config.ts can validate AuthKit JWTs.
WORKOS_CLIENT_ID=

# Next.js: WorkOS AuthKit server credentials and callback URL.
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# Convex: Primary AI provider used by agents and most AI product flows.
OPENROUTER_API_KEY=

# Next.js + Convex: Public site URL used by auth and X callbacks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Convex: Site URL used for webhook registration and callback construction.
# Convex provides this system variable automatically; only override it when
# intentionally using custom deployment domains.
# Example: https://your-deployment.convex.site
CONVEX_SITE_URL=

# ============================================
# Feature: X/Twitter
# ============================================

# X OAuth app
X_API_CLIENT_ID=
X_API_CLIENT_SECRET=
X_API_BEARER_TOKEN=

# OAuth 1.0 Consumer Secret (API Key Secret) — required for webhook CRC + POST signatures (not the OAuth 2 client secret above)
X_CONSUMER_SECRET=

# Secret used to encrypt stored X access/refresh tokens before persisting them
X_TOKEN_ENCRYPTION_KEY=

# ============================================
# Feature: LinkedIn
# ============================================

# LinkedIn search and profile data
LINKDAPI_API_KEY=

# LinkedIn messaging and actions
UNIPILE_API_KEY=
UNIPILE_BASE_URL=
UNIPILE_WEBHOOK_SECRET=

# ============================================
# Feature: External Services
# ============================================

# Twitter search, hydration, and monitoring
SOCIALAPI_API_KEY=

# Waitlist welcome email. General application email is not implemented yet.
RESEND_API_KEY=

# ============================================
# Feature: Billing
# ============================================

POLAR_ORGANIZATION_TOKEN=
POLAR_PRODUCT_HOBBY_MONTHLY=
POLAR_PRODUCT_HOBBY_YEARLY=
POLAR_PRODUCT_BASE_MONTHLY=
POLAR_PRODUCT_BASE_YEARLY=
POLAR_PRODUCT_PRO_MONTHLY=
POLAR_PRODUCT_PRO_YEARLY=

# Optional. Defaults to sandbox if unset.
# POLAR_SERVER=sandbox

# ============================================
# Optional: AI Providers And Fallbacks
# ============================================

# Preferred native provider for OpenAI embedding models. If it is absent,
# embeddings use OPENROUTER_API_KEY instead.
OPENAI_API_KEY=

# Reserved/currently unused by the application. Setting these has no effect yet.
XAI_API_KEY=
# XAI_BASE_URL=

# ============================================
# Optional: AI Model Routing
# ============================================

# Stable workload roles. Values are OpenRouter model IDs and can be replaced
# without changing code or environment variable names.
# AI_FAST_MODEL=openai/gpt-oss-120b
# AI_REASONING_MODEL=openai/gpt-oss-120b
# AI_AUTOCOMPLETE_MODEL=openai/gpt-oss-120b
# AI_SETUP_AGENT_MODEL=openai/gpt-oss-120b
# AI_MAIN_AGENT_MODEL=openai/gpt-5.6-terra
# AI_OUTREACH_ROUTER_MODEL=openai/gpt-5.6-luna
# AI_OUTREACH_FAST_MODEL=openai/gpt-oss-120b
# AI_OUTREACH_STANDARD_MODEL=openai/gpt-5.6-terra
# AI_OUTREACH_RECOVERY_MODEL=openai/gpt-5.6-sol
# AI_VISION_MODEL=moonshotai/kimi-k2.6
# AI_TEXT_EMBEDDING_MODEL=openai/text-embedding-3-small

# Fallback routing for AI_FAST_MODEL and AI_REASONING_MODEL when those role
# variables are not configured. Valid values: current, cost_optimized.
# OPENROUTER_ROUTING_PRESET=cost_optimized

# ============================================
# Optional: Product And Content Helpers
# ============================================

# URL content extraction
EXA_API_KEY=

# Keyword discovery
BISHOPI_API_KEY=

# GitHub API token for higher-rate metadata fetches
GITHUB_TOKEN=

# ============================================
# Optional: Analytics & Monitoring
# ============================================

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================
# Optional: Rate Limits And Runtime Tuning
# ============================================

# Continuous real-workflow scheduling (no setup preview behavior).
# Recommended: 0 in development and 1 in production.
# PROSPECTING_AUTO_RESCHEDULE=1
# PROSPECTING_RESCHEDULE_INTERVAL_MINUTES=60
# PROSPECTING_BOOTSTRAP_READY_TARGET=12
# PROSPECTING_BOOTSTRAP_INTERVAL_MINUTES=2
# PROSPECTING_BOOTSTRAP_MAX_CYCLES=8
# This is time without meaningful progress, not total bootstrap elapsed time.
# PROSPECTING_BOOTSTRAP_NO_PROGRESS_TIMEOUT_MINUTES=20
# PROSPECTING_BOOTSTRAP_PENDING_QUALIFICATION_YIELD_PERCENT=30

# Discovery volume per real prospecting cycle
# PROSPECTING_SEED_KEYWORDS_PER_CYCLE=10
# PROSPECTING_SOCIAL_QUERIES_PER_CYCLE=15
# PROSPECTING_TWITTER_SEARCH_BATCH=5
# PROSPECTING_LINKEDIN_POST_SEARCH_BATCH=5
# PROSPECTING_LINKEDIN_PEOPLE_SEARCH_BATCH=4

# Prospecting failure recovery and per-step retries
# PROSPECTING_RECOVERY_BASE_DELAY_MINUTES=60
# PROSPECTING_RECOVERY_MAX_DELAY_MINUTES=240
# PROSPECTING_RECOVERY_JITTER_MINUTES=10
# PROSPECTING_AI_RETRY_MAX_ATTEMPTS=3
# PROSPECTING_AI_RETRY_INITIAL_BACKOFF_MS=1000
# PROSPECTING_PROVIDER_RETRY_MAX_ATTEMPTS=2
# PROSPECTING_PROVIDER_RETRY_INITIAL_BACKOFF_MS=2000
# PROSPECTING_AUXILIARY_RETRY_MAX_ATTEMPTS=2
# PROSPECTING_AUXILIARY_RETRY_INITIAL_BACKOFF_MS=1000
# PROSPECTING_RETRY_BACKOFF_BASE=2

# SocialAPI and LinkdAPI shared request budgets
# SOCIALAPI_REQUESTS_PER_MINUTE=500
# SOCIALAPI_TARGET_REQUESTS_PER_MINUTE=300
# SOCIALAPI_BUDGET_RESERVATION_MAX_ATTEMPTS=12
# SOCIALAPI_OCC_RETRY_BASE_MS=25
# SOCIALAPI_OCC_RETRY_JITTER_MS=40
# LINKDAPI_REQUESTS_PER_MINUTE=30
# LINKDAPI_TARGET_REQUESTS_PER_MINUTE=24
# LINKDAPI_BUDGET_RESERVATION_MAX_ATTEMPTS=12
# LINKDAPI_OCC_RETRY_BASE_MS=25
# LINKDAPI_OCC_RETRY_JITTER_MS=40

# Qualification, enrichment, and outreach workpool controls
# QUALIFICATION_MAX_PARALLELISM=10
# QUALIFICATION_RETRY_MAX_ATTEMPTS=3
# QUALIFICATION_RETRY_INITIAL_BACKOFF_MS=1000
# ENRICHMENT_MAX_PARALLELISM=10
# ENRICHMENT_RETRY_MAX_ATTEMPTS=3
# ENRICHMENT_RETRY_INITIAL_BACKOFF_MS=1000
# OUTREACH_PLAN_MAX_PARALLELISM=5
# OUTREACH_PLAN_RETRY_MAX_ATTEMPTS=3
# OUTREACH_PLAN_RETRY_INITIAL_BACKOFF_MS=2000
# WORKPOOL_RETRY_BACKOFF_BASE=2

# Shared provider circuit breaker behavior
# PROVIDER_CIRCUIT_PROBE_INTERVAL_SECONDS=120
# PROVIDER_CIRCUIT_PROBE_LEASE_SECONDS=30
# PROVIDER_TRANSIENT_FAILURES_BEFORE_OPEN=3
# PROVIDER_RATE_LIMIT_RETRY_SECONDS=60
# PROVIDER_TRANSIENT_RETRY_SECONDS=60

# ============================================
# Optional: Feature Flags
# ============================================

# Show a site-wide banner (landing + app) when the backend is down/degraded.
# Set to true/1/yes/on to show. Remove or set false to hide.
# NEXT_PUBLIC_BACKEND_STATUS_BANNER=true
# Optional message override (defaults to a clear downtime notice):
# NEXT_PUBLIC_BACKEND_STATUS_BANNER_MESSAGE=Backend is temporarily unavailable. Some features may not work right now.

# Reserved/currently unused by the application. Setting this has no effect yet.
# NEXT_PUBLIC_DISABLE_LLM_FILTER=

# Enable the fast partial setup preview path
# SETUP_PREVIEW_FAST_PATH=1
