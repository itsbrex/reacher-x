# ============================================
# ReacherX Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ============================================
# Required: Core Configuration
# ============================================

# Convex Database
# Get this from your Convex dashboard after running `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=

# Authentication (WorkOS)
# Get these from https://workos.com
WORKOS_CLIENT_ID=

# ============================================
# Required: Social Platform APIs
# ============================================

# X OAuth app
# Get these from the X developer portal
X_API_CLIENT_ID=
X_API_CLIENT_SECRET=
X_API_BEARER_TOKEN=

# OAuth 1.0 Consumer Secret (API Key Secret) — required for webhook CRC + POST signatures (not the OAuth 2 client secret above)
X_CONSUMER_SECRET=

# Secret used to encrypt stored X access/refresh tokens before persisting them
X_TOKEN_ENCRYPTION_KEY=

# ============================================
# Required: External Services
# ============================================

# Exa API (for URL description)
# Get this from https://exa.ai
EXA_API_KEY=

# Resend API (for email sending)
# Get this from https://resend.com
RESEND_API_KEY=

# ============================================
# Optional: AI Providers (at least one recommended)
# ============================================

# OpenAI (for AI keyword generation and filtering)
# Get this from https://platform.openai.com
OPENAI_API_KEY=

# xAI Grok (for better Twitter understanding)
# Get this from https://x.ai
XAI_API_KEY=
# Optional: Custom xAI base URL (defaults to https://api.x.ai/v1)
# XAI_BASE_URL=

# ============================================
# Optional: Social Search APIs
# ============================================

# LinkedIn Search (via LinkdAPI)
# Get this from https://linkdapi.com
LINKDAPI_API_KEY=
# Optional: Custom LinkdAPI base URL (defaults to https://linkdapi.com)
# LINKDAPI_BASE_URL=

# SocialAPI (for Twitter hydration and monitoring)
# Get this from https://socialapi.io
SOCIALAPI_API_KEY=

# ============================================
# Optional: Site Configuration
# ============================================

# Site URL (used for connect links and callbacks)
# Defaults to http://localhost:3000 in development
NEXT_PUBLIC_SITE_URL=

# ============================================
# Optional: Analytics & Monitoring
# ============================================

# PostHog Analytics
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================
# Optional: Feature Flags
# ============================================

# Disable AI filtering (for testing)
# NEXT_PUBLIC_DISABLE_LLM_FILTER=

# Enable the fast partial setup preview path
# SETUP_PREVIEW_FAST_PATH=1
